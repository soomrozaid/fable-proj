# Scanstone environment contract (canonical, framework-neutral names).
# Copy to .env.local for development. NEVER commit real values.
#
# Public values (safe for the browser) are aliased to NEXT_PUBLIC_* at build
# time in next.config.ts — do not add NEXT_PUBLIC_* names here.

# Absolute URL of this deployment (no trailing slash), e.g. http://localhost:3000
APP_URL=

# Supabase project (Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Secret (server-only). Bypasses RLS — never expose to the browser.
SUPABASE_SECRET_KEY=

# Stripe (Dashboard → Developers → API keys). Use test keys in development.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint (or from `stripe listen` in dev)
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs for the Pro plan
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
